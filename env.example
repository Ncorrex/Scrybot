# Scrybot Configuration Example
# Copy this file to .env and fill in your actual values

# REQUIRED: Discord Webhook URL for notifications
# See: https://discord.com/developers/docs/resources/webhook
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# OPTIONAL: How often to check Scryfall (default: 1h)
# Format: Go duration (e.g., 30m, 1h, 5m)
POLL_INTERVAL=1h

# OPTIONAL: Directory to store state/cache (default: /root/data)
# In Docker/CasaOS, this should be a mounted volume path
DATA_DIR=/root/data

# OPTIONAL: Scryfall search query (default: is:firstprinting sort:released)
# Examples:
#   is:firstprinting sort:released          - All new printings (recommended)
#   is:preview                               - Spoilers and previews
#   set:mkm                                  - Specific set (MKM = Murders at Karlov Manor)
#   type:legendary sort:released             - Legendary creatures only
#   rarity>=rare sort:released               - Rares and mythics only
SEARCH_QUERY=is:firstprinting sort:released

